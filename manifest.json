{
  "manifest_version": 3,
  "name": "Alicia AI - Job Assistant",
  "version": "1.8.2",
  "description": "AI-powered job search assistant for LinkedIn",
  "permissions": ["sidePanel", "activeTab", "storage", "unlimitedStorage", "tabs", "scripting", "webNavigation"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_title": "Alicia AI - Job Assistant"
  }
}
