{
  "manifest_version": 3,
  "name": "Alicia AI - Job Assistant",
  "version": "1.13.28",
  "description": "AI-powered job search assistant for LinkedIn",
  "permissions": [
    "sidePanel",
    "activeTab",
    "storage",
    "unlimitedStorage",
    "tabs",
    "scripting",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "https://wagner-gpt.vercel.app/*",
        "http://localhost/*"
      ],
      "js": [
        "bridge.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_title": "Alicia AI - Job Assistant"
  }
}
