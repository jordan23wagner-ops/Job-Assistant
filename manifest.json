{
  "manifest_version": 3,
  "name": "Alicia AI - Job Assistant",
  "version": "0.2.1",
  "description": "AI-powered job search assistant for LinkedIn",
  "permissions": ["sidePanel", "activeTab", "storage", "tabs", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Alicia AI - Job Assistant"
  }
}